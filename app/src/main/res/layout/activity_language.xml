<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose Your Language"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select your preferred language for the app"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="@color/gray"
        android:layout_marginBottom="32dp" />

    <!-- Language selection UI would go here -->
    <TextView
        android:id="@+id/tvSelectedLanguage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="English"
        android:textSize="18sp"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/legal_light_blue"
        android:textColor="@color/legal_blue"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue"
        android:textSize="18sp"
        android:backgroundTint="@color/legal_blue" />

</LinearLayout>