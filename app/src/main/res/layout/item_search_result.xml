<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.LegalEase.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Result Icon -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/resultIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@color/legal_blue_light"
            android:padding="12dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.LegalEase.Circle"
            app:tint="@color/legal_blue" />

        <!-- Result Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Category Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/categoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.LegalEase.LabelSmall" />

            <!-- Title -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.LegalEase.TitleMedium" />

            <!-- Description -->
            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="@style/TextAppearance.LegalEase.BodyMedium"
                android:textColor="@color/text_secondary" />

            <!-- Match Details -->
            <TextView
                android:id="@+id/matchText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.LegalEase.LabelMedium"
                android:textColor="@color/legal_blue" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>