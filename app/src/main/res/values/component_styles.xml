<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Button Styles -->
    <style name="Widget.LegalEase.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="elevation">2dp</item>
        <item name="rippleColor">@color/scrim_light</item>
    </style>

    <style name="Widget.LegalEase.Button.Secondary" parent="Widget.LegalEase.Button">
        <item name="backgroundTint">@color/legal_gold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.LegalEase.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="strokeColor">@color/legal_blue</item>
        <item name="rippleColor">@color/scrim_light</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.LegalEase.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="rippleColor">@color/scrim_light</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.LegalEase.Card.Elevated" parent="Widget.LegalEase.Card">
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Widget.LegalEase.Card.Outlined" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/legal_blue_light</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="rippleColor">@color/scrim_light</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Input Field Styles -->
    <style name="Widget.LegalEase.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.LegalEase.InputHint</item>
    </style>

    <style name="TextAppearance.LegalEase.InputHint" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Bottom Sheet Styles -->
    <style name="Widget.LegalEase.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.LegalEase.LargeComponent</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="behavior_peekHeight">400dp</item>
        <item name="behavior_hideable">true</item>
        <item name="behavior_skipCollapsed">false</item>
    </style>

    <!-- List Item Styles -->
    <style name="Widget.LegalEase.ListItem" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="rippleColor">@color/scrim_light</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>
</resources>