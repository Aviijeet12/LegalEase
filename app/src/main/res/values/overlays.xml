<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ThemeOverlay.LegalEase.SearchView" parent="ThemeOverlay.Material3">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorOnSurfaceVariant">@color/gray</item>
        <item name="colorSurface">@color/white</item>
        <item name="searchViewStyle">@style/Widget.LegalEase.SearchView</item>
    </style>

    <style name="Widget.LegalEase.SearchView" parent="Widget.Material3.SearchView">
        <item name="queryBackground">@color/white</item>
        <item name="submitBackground">@color/white</item>
        <item name="android:iconifiedByDefault">false</item>
        <item name="android:queryHint">Search...</item>
        <item name="android:maxWidth">10000dp</item>
    </style>
</resources>